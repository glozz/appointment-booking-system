@model IEnumerable<AppointmentBooking.Application.DTOs.ConsultantDto>
@{
    ViewData["Title"] = "Select Consultant";
    var returnAction = ViewBag.ReturnAction as string ?? "Dashboard";
    var returnDate = ViewBag.ReturnDate as DateTime?;
    var activeConsultants = Model.Where(c => c.IsActive).ToList();
    var inactiveConsultants = Model.Where(c => !c.IsActive).ToList();
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1><i class="bi bi-people text-primary"></i> Select Consultant</h1>
                    <p class="text-muted mb-0">
                        Choose a consultant to view their schedule
                    </p>
                </div>
            </div>
            
            <div class="alert alert-info mb-4">
                <i class="bi bi-shield-check"></i> 
                <strong>Admin Access:</strong> As an administrator, you can view any consultant's schedule. 
                Select a consultant below to continue.
            </div>
            
            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var consultant in activeConsultants)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 consultant-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" 
                                             style="width: 50px; height: 50px; font-size: 1.25rem;">
                                            @(consultant.FirstName.Substring(0, 1))@(consultant.LastName.Substring(0, 1))
                                        </div>
                                        <div class="ms-3">
                                            <h5 class="card-title mb-0">@consultant.FullName</h5>
                                            <small class="text-muted">
                                                <i class="bi bi-building"></i> Branch #@consultant.BranchId
                                            </small>
                                        </div>
                                    </div>
                                    <p class="card-text text-muted small">
                                        <i class="bi bi-person-badge"></i> Consultant ID: @consultant.Id
                                    </p>
                                </div>
                                <div class="card-footer bg-transparent border-0 pb-3">
                                    @if (returnAction == "Schedule" && returnDate.HasValue)
                                    {
                                        <a asp-action="@returnAction" 
                                           asp-route-consultantId="@consultant.Id"
                                           asp-route-date="@returnDate.Value.ToString("yyyy-MM-dd")"
                                           class="btn btn-primary w-100">
                                            <i class="bi bi-calendar-check"></i> View Schedule
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="@returnAction" 
                                           asp-route-consultantId="@consultant.Id"
                                           class="btn btn-primary w-100">
                                            <i class="bi bi-calendar-check"></i> View Schedule
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
                
                @if (inactiveConsultants.Any())
                {
                    <hr class="my-4" />
                    <h5 class="text-muted mb-3">
                        <i class="bi bi-person-x"></i> Inactive Consultants (@inactiveConsultants.Count)
                    </h5>
                    <div class="row">
                        @foreach (var consultant in inactiveConsultants)
                        {
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 opacity-50">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-3">
                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" 
                                                 style="width: 50px; height: 50px; font-size: 1.25rem;">
                                                @(consultant.FirstName.Substring(0, 1))@(consultant.LastName.Substring(0, 1))
                                            </div>
                                            <div class="ms-3">
                                                <h5 class="card-title mb-0">@consultant.FullName</h5>
                                                <small class="text-muted">
                                                    <i class="bi bi-building"></i> Branch #@consultant.BranchId
                                                </small>
                                            </div>
                                        </div>
                                        <span class="badge bg-secondary">Inactive</span>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pb-3">
                                        @if (returnAction == "Schedule" && returnDate.HasValue)
                                        {
                                            <a asp-action="@returnAction" 
                                               asp-route-consultantId="@consultant.Id"
                                               asp-route-date="@returnDate.Value.ToString("yyyy-MM-dd")"
                                               class="btn btn-outline-secondary w-100">
                                                <i class="bi bi-calendar-check"></i> View Schedule
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="@returnAction" 
                                               asp-route-consultantId="@consultant.Id"
                                               class="btn btn-outline-secondary w-100">
                                                <i class="bi bi-calendar-check"></i> View Schedule
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-people display-1 text-muted"></i>
                        <h4 class="mt-3">No Consultants Available</h4>
                        <p class="text-muted">There are no consultants registered in the system yet.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .consultant-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .consultant-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
</style>
